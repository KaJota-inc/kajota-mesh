# Kajota Mesh — Mantle Turing Test hackathon (Jun 15, 2026) env.
#
# Copy to `.env.mantle-turing` (gitignored) before running the mesh
# deploy + attestation flow against Mantle Sepolia. Pairs with the
# "Mantle Turing Test" section of `HACKS.md` for the credential-mint
# checklist.

# ---- Networks -----------------------------------------------------

# Mantle Sepolia is the primary deploy target for this hack. The
# public endpoint rate-limits hard on dev-loop calls — swap in a
# managed RPC (Alchemy / QuickNode) before recording the demo.
MANTLE_SEPOLIA_RPC=https://rpc.sepolia.mantle.xyz

# Optional — Base Sepolia cross-deploy for the cross-chain story.
BASE_SEPOLIA_RPC=https://sepolia.base.org

# Deployer EOA private key (hex, 0x-prefixed). Must hold a small
# amount of Mantle Sepolia MNT for gas — claim at
# https://faucet.sepolia.mantle.xyz
DEPLOYER_PRIVATE_KEY=0x...

# ---- Mantle-specific reference addresses --------------------------

# TODO(mantle-turing): pin Mantle Sepolia USDC / native-token
# addresses once confirmed against the Mantle docs.
USDC_MANTLE_SEPOLIA=

# ---- Block-explorer verify ----------------------------------------

# Mantlescan API key — create at
# https://explorer.sepolia.mantle.xyz/api-keys
MANTLESCAN_API_KEY=

# ---- Turing-Test-specific config ----------------------------------

# TODO(mantle-turing): anything the Mantle Turing track explicitly
# requires (judge attestation endpoint, evaluator pubkey, etc.) once
# the prize prompt publishes.
TURING_TEST_TODO=
