# Kajota Mesh — env vars for deploy + attestation.
# Copy to `.env` (gitignored) before running `pnpm --filter @kajota-mesh/contracts deploy:base-sepolia`.

# ---- Networks -----------------------------------------------------

# Base Sepolia RPC. Free public endpoint works for one-shot deploys;
# for repeated calls (e.g. dev loop) use an Alchemy / Infura / QuickNode
# endpoint to avoid rate limits.
BASE_SEPOLIA_RPC=https://sepolia.base.org

# Optional — Mantle Sepolia, if/when we cross-deploy for Turing Test.
MANTLE_SEPOLIA_RPC=https://rpc.sepolia.mantle.xyz

# Arbitrum Sepolia RPC — target for Arbitrum Open House London (Jun 14, 2026).
ARBITRUM_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc

# Deployer EOA private key (hex, 0x-prefixed). MUST have a small
# amount of Base Sepolia ETH for gas — grab from
# https://www.alchemy.com/faucets/base-sepolia
DEPLOYER_PRIVATE_KEY=0x...

# ---- Reference deployed addresses ---------------------------------

# Circle's USDC on Base Sepolia (6-decimal, native CCTP).
# Source: https://developers.circle.com/stablecoins/usdc-on-test-networks
USDC_BASE_SEPOLIA=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# Circle's USDC on Arbitrum Sepolia (6-decimal, native).
# Source: https://developers.circle.com/stablecoins/usdc-contract-addresses
USDC_ARBITRUM_SEPOLIA=0x75faf114eafb1BDbe2F0316DF893fd58CE46AA4d

# ---- Release auth -------------------------------------------------

# Initial `releaseAuth` for CosellEscrow. In production this would
# be a Chainlink Functions consumer contract; for the v0 demo it
# can be a multisig or a single ops EOA. Defaults to deployer if
# unset.
INITIAL_RELEASE_AUTH=

# ---- Etherscan / Basescan verify ----------------------------------

# Get a free key at https://basescan.org/myapikey
BASESCAN_API_KEY=

# ---- Chainlink Functions ------------------------------------------

# Subscription id created via https://functions.chain.link
CHAINLINK_FUNCTIONS_SUB_ID=

# DON id for Base Sepolia: fun-base-sepolia-1
CHAINLINK_FUNCTIONS_DON_ID=fun-base-sepolia-1

# ---- Kajota backend (attestation source) --------------------------

# Base URL the Functions DON calls to fetch a signed
# shipment-confirmed claim for a given orderId.
KAJOTA_ATTESTATION_BASE=https://kajota-mobile-backend-2.onrender.com/kajota-mobile-backend

# Bearer token the Functions DON uses to call the attestation
# endpoint. Service-account scoped (read-only).
KAJOTA_ATTESTATION_TOKEN=
